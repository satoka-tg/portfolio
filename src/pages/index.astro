---
import Layout from "~/layouts/Layout.astro";
import About from "~/components/pages/about.astro";
import Works from "~/components/pages/works.astro";
import Skills from "~/components/pages/skills.astro";

const page = {
  title: "ポートフォリオサイト",
  description: "STのポートフォリオサイトです。",
  bodyClass: "home",
  sitename: "",
};
---

<Layout
  title={page.title}
  description={page.description}
  bodyClass={page.bodyClass}
  sitename={page.sitename}
>
  <About />
  <Works />
  <Skills />
</Layout>
