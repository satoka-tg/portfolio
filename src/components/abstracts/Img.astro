---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';

type Props = {
	srcPaths: [string, string?];
	mediaQuery?: number;
	classNames?: string;
	alt?: string;
	loading?: 'lazy' | 'eager';
	format?: 'webp' | 'avif';
};

const { srcPaths, mediaQuery = 768, classNames, alt = '', loading = 'lazy', format = 'webp' } = Astro.props;

const importImage = async (src: string) => {
	const imageFile = import.meta.glob<{ default: ImageMetadata }>('/src/images/**/*');

	if (!imageFile[`/src/images/${src}`]) return;
	const moduleImage = await imageFile[`/src/images/${src}`]();

	const { default: imageSrc } = moduleImage;

	// WebP画像を取得（ハッシュを付与しない設定）
	const webpImage = await getImage({
		src: imageSrc,
		format: format,
		hash: false,
	});
	const { loading: loadingMode, ...attributes } = webpImage.attributes;

	return { originalSrc: imageSrc.src, webpSrc: webpImage.src, attributes };
};

const importImages = async () => {
	return Promise.all(
		srcPaths.map(async (src) => {
			if (!src) return;
			return importImage(src);
		})
	);
};

const images = await importImages();
---

{
	(
		<>
			{images.length === 1 ? (
				<picture class:list={[classNames]}>
					<source srcset={images[0]?.webpSrc} type="image/webp" />
					<img src={images[0]?.originalSrc} {...images[0]?.attributes} loading={loading} alt={alt} />
				</picture>
			) : (
				<picture class:list={[classNames]}>
					<source media={`(max-width: ${mediaQuery}px)`} srcset={images[1]?.webpSrc} type="image/webp" />
					<source media={`(max-width: ${mediaQuery}px)`} srcset={images[1]?.originalSrc} />
					<source srcset={images[0]?.webpSrc} type="image/webp" />
					<img src={images[0]?.originalSrc} {...images[0]?.attributes} loading={loading} alt={alt} />
				</picture>
			)}
		</>
	)
}
