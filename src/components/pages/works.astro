---
import Img from "~/components/abstracts/Img.astro";

type WorksGroup = {
  category: string;
  items: Work[];
};

type Work = {
  categorie: string;
  title: string;
  url: string;
  tags: string[];
  period: string;
  overview: string;
  role: string[];
