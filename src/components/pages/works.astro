const groupedWorks: WorksGroup[] = worksData.reduce((acc, work) => {
  const group = acc.find((g) => g.category === work.categorie);

  if (group) {
    group.items.push(work);
  } else {
    acc.push({
      category: work.categorie,
      items: [work],
    });
  }

  return acc;
}, [] as WorksGroup[]);
---

<section id="works">
  <div class="aside">
    <h2>WORKS</h2>
  </div>
  <div class="content">
    <ul class="works-list">
      {
        worksData.map((work, index) => (
          <li>
            <button
              class="item"
              data-index={index}
              aria-haspopup="dialog"
              aria-label={`${work.categorie}の詳細を見る`}
            >
              <h3>{work.categorie}</h3>
              <Img
                srcPaths={[
                  `pages/works-${index + 1}_pc.jpg`,
                  `pages/works-${index + 1}_sp.jpg`,
                ]}
                alt={work.categorie}
                classNames="image"
              />
            </button>
          </li>
        ))
      }
    </ul>
  </div>
</section>

{
  worksData.map((work, index) => (
    <dialog id={`modal-${index}`} class="modal">
      <div class="modal-side">
        <p class="num">01</p>
        <p class="cat">{work.categorie}</p>
      </div>
      <div class="modal-inner">
        <div class="modal-image">
          <a href={work.url} target="_blank" rel="noopener noreferrer">
            <Img
              srcPaths={[
                `pages/works-${index + 1}_pc.jpg`,
                `pages/works-${index + 1}_sp.jpg`,
              ]}
              alt={work.title}
            />
          </a>
        </div>
        <div class="modal-cont">
          {/* <p class="modal-index">{String(index + 1).padStart(2, "0")}</p> */}
          <h3 class="modal-title">{work.title}</h3>
          <a
            href={work.url}
            class="modal-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            {work.url}
          </a>
          <ul class="modal-tags">
            {work.tags.map((c) => (
              <li>{c}</li>
            ))}
          </ul>
          <p class="modal-period">期間：{work.period}</p>
          <dl class="modal-detail">
            <div class="modal-row">
              <dt>概要</dt>
              <dd>{work.overview}</dd>
            </div>
            <div class="modal-row">
              <dt>担当</dt>
              <dd>{work.role.join(", ")}</dd>
            </div>
            <div class="modal-row">
              <dt>課題</dt>
              <dd>{work.challenge}</dd>
            </div>
            <div class="modal-row">
              <dt>取り組み</dt>
              <dd>{work.approach}</dd>
            </div>
            <div class="modal-row">
              <dt>成果</dt>
              <dd>{work.result}</dd>
            </div>
            <div class="modal-row">
              <dt>使用技術</dt>
              <dd>{work.technologies.join(", ")}</dd>
            </div>
          </dl>
        </div>
      </div>
      <div class="modal-button">
        <button class="modal-prev" aria-label="前へ" />
        <p class="modal-pager">
          <span>1</span>/<span>4</span>
        </p>
        <button class="modal-next" aria-label="次へ" />
      </div>
      <button class="modal-close" aria-label="閉じる">
        <span />
        <span />
      </button>
    </dialog>
  ))
}
