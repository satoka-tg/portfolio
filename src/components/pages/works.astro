---

<section id="works">
  <div class="aside">
    <h2>WORKS</h2>
  </div>
  <div class="content">
    <ul class="works-list">
      {
        worksData.map((work, index) => (
          <li>
            <button
              class="item"
              data-index={index}
              aria-haspopup="dialog"
              aria-label={`${work.title}の詳細を見る`}
            >
              <h3>{work.title}</h3>
              <Img
                srcPaths={[work.image]}
                alt={work.title}
                classNames="image"
              />
            </button>
          </li>
        ))
      }
    </ul>
  </div>
</section>

{
  worksData.map((work, index) => (
    <dialog id={`modal-${index}`} class="modal">
      <div class="modal-inner">
        <Img
          srcPaths={[work.image]}
          alt={work.title}
          classNames="modal-image"
        />
        <div class="modal-cont">
          <button class="modal-close" aria-label="閉じる">
            <span />
            <span />
          </button>
          <p class="modal-index">{String(index + 1).padStart(2, "0")}</p>
          <h3 class="modal-title">
            <a href={work.url} target="_blank" rel="noopener noreferrer">
              {work.title}
            </a>
          </h3>
          <ul class="modal-categories">
            {work.categories.map((c) => (
              <li>{c}</li>
            ))}
          </ul>
          <p class="modal-period">期間：{work.period}</p>
          <dl class="modal-detail">
            <div class="modal-row">
              <dt>概要</dt>
              <dd>{work.overview}</dd>
            </div>
            <div class="modal-row">
              <dt>担当</dt>
              <dd>{work.role.join(", ")}</dd>
            </div>
            <div class="modal-row">
              <dt>課題</dt>
              <dd>{work.challenge}</dd>
            </div>
            <div class="modal-row">
              <dt>取り組み</dt>
              <dd>{work.approach}</dd>
            </div>
            <div class="modal-row">
              <dt>成果</dt>
              <dd>{work.result}</dd>
            </div>
            <div class="modal-row">
              <dt>使用技術</dt>
              <dd>{work.technologies.join(", ")}</dd>
            </div>
          </dl>
        </div>
      </div>
    </dialog>
  ))
}
